COMPOSE_PROJECT_NAME=interstellar

# Local-only demo value. Replace in real deployments and never commit .env.
POSTGRES_DB=interstellar
POSTGRES_USER=interstellar_app
POSTGRES_PASSWORD=change-me-generate-a-strong-local-secret
POSTGRES_PORT=5432

CAREERFORGE_PORT=8080
CAREERFORGE_RUST_LOG=careerforge_api=info,tower_http=info
CAREERFORGE_DATABASE_URL=postgres://interstellar_app:change-me-generate-a-strong-local-secret@postgres:5432/interstellar

TASK_MANAGER_PORT=3000
TASK_MANAGER_RUST_LOG=info
TASK_MANAGER_DATABASE_URL=postgres://interstellar_app:change-me-generate-a-strong-local-secret@postgres:5432/interstellar

